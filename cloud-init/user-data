#cloud-config

package_update: true

users:
  - default
  - name: ${vm_username}
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - ${ssh_public_key}

packages:
  - qemu-guest-agent
  - curl

timezone: ${timezone}

runcmd:
  - systemctl enable --now qemu-guest-agent
  - |
    set -e
    curl -fsSL https://tailscale.com/install.sh | sh
    systemctl enable tailscaled
    systemctl start tailscaled
    until systemctl is-active --quiet tailscaled; do
    	sleep 2
    done
    tailscale up --authkey=${tailscale_auth_key}

    for i in $(seq 1 120); do
      TS_IP=$(ip -4 addr show tailscale0 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
      if [ -n "$TS_IP" ]; then
        DASHED_IP=$(echo "$TS_IP" | sed 's/\./-/g')
        hostnamectl set-hostname "${hostname_prefix}-$DASHED_IP"
        echo "$TS_IP" > /root/tailscale-ip.txt
        break
      fi
      sleep 2
    done

power_state:
  mode: reboot
  message: "Cloud-init complete. Rebooting to apply changes."
  timeout: 10
  condition: true
